{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "dev",
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "typescript",
					"source": "ts",
					"applyTo": "allDocuments",
					"fileLocation": ["relative", "${cwd}"],
					"pattern": {
						"regexp": "^(?<file>.+) \\((?<line>\\d+):(?<column>\\d+)\\) .*Error:\\s(?<message>.+)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"message": 4
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": {
							"regexp": "."
						},
						"endsPattern": {
							"regexp": "^(Waiting for changes\\.\\.\\.|✔ Rebuilt out in .+)$"
						}
					}
				}
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"showReuseMessage": false,
				"clear": true
			},
			"group": "build"
		}
	]
}
